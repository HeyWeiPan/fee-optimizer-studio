# Bags API key obtained via `pnpm tsx scripts/bags-auth.ts`.
# DO NOT commit a real key. The script also writes to ~/.config/fee-optimizer-studio/bags-key.txt
# which is the recommended source-of-truth for local dev.
BAGS_API_KEY=

# Solana RPC for chain reads (holder count fallback, tx confirmation polling).
# Free public mainnet RPC is fine for local dev; switch to Helius/Triton for production.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Token gating (off by default; flip on once the gating mint is live)
GATING_ENABLED=0
FOSTUDIO_MINT=
PRO_THRESHOLD=1
